{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web-dist",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "python3 -m http.server \"${PORT:-8090}\" --directory app/build/dist/wasmJs/productionExecutable"],
      "port": 8090,
      "autoPort": true
    },
    {
      "name": "web-js",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "python3 -m http.server \"${PORT:-8091}\" --directory web/build/dist/js/productionExecutable"],
      "port": 8091,
      "autoPort": true
    },
    {
      "name": "backend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "ADMIN_EMAIL=admin@tbb.org ADMIN_PASSWORD=admin-secret-123 ./gradlew :server:run"],
      "port": 8080
    }
  ]
}
